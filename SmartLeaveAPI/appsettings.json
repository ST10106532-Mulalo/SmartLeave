{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=SmartLeaveDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "EmailValidation": {
    "Enabled": true,
    "StrictMode": true,
    "Rules": [
      {
        "Name": "Employees",
        "AllowedDomains": [ "company.com", "company.co.za" ],
        "UsernamePattern": "^[a-zA-Z]+\\.[a-zA-Z]+$",
        "Description": "firstname.lastname@company.com",
        "IsActive": true
      },
      {
        "Name": "Contractors",
        "AllowedDomains": [ "contractor.com", "external-partner.com" ],
        "UsernamePattern": null,
        "Description": "Contractor email domains",
        "IsActive": true
      },
      {
        "Name": "External",
        "AllowedDomains": [ "gmail.com", "outlook.com", "yahoo.com", "hotmail.com" ],
        "UsernamePattern": null,
        "Description": "Personal email providers",
        "IsActive": true
      }
    ]
  },
  "Jwt": {
    "Key": "SmartLeave_Secret_Key_2026_Secure_32_Characters_Minimum!",
    "Issuer": "SmartLeaveAPI",
    "Audience": "SmartLeaveClient",
    "DurationInDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}